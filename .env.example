# Database (Neon or Supabase PostgreSQL connection string)
DATABASE_URL="postgresql://user:password@host:5432/giem?sslmode=require"

# Auth (generate with: openssl rand -hex 32)
AUTH_PASSWORD="your-secure-password-here"
JWT_SECRET="your-jwt-secret-here-generate-with-openssl-rand-hex-32"

# Telegram Bot
TELEGRAM_BOT_TOKEN="123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11"
TELEGRAM_CHAT_ID="your-telegram-chat-id"
TELEGRAM_WEBHOOK_SECRET="your-webhook-secret-generate-random"

# AI (OpenAI — optional, falls back to rule-based)
OPENAI_API_KEY="sk-..."

# App URL (set to your Vercel deployment URL)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# Cron secret (for Vercel Cron Jobs auth)
CRON_SECRET="your-cron-secret-generate-random"
